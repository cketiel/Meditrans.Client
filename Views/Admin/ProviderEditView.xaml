<Window x:Class="Meditrans.Client.Views.Admin.ProviderEditView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Provider Details" Height="550" Width="500" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!--<ScrollViewer Grid.Row="0">-->
            <StackPanel Margin="20">
                <TextBlock Text="Transport Provider Information" Style="{StaticResource MaterialDesignHeadline5TextBlock}" Margin="0,0,0,20"/>

                <TextBox materialDesign:HintAssist.Hint="Company Name" Text="{Binding Provider.Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,15"/>
                <TextBox materialDesign:HintAssist.Hint="Address" Text="{Binding Provider.Address, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,15"/>
                <TextBox materialDesign:HintAssist.Hint="Email" Text="{Binding Provider.Email, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,15"/>
                <TextBox materialDesign:HintAssist.Hint="Phone" Text="{Binding Provider.Phone, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,15"/>

                <TextBlock Text="Company Logo" Style="{StaticResource MaterialDesignCaptionTextBlock}" Margin="0,10,0,5"/>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,20">
                    <Border Width="120" Height="120" CornerRadius="5" BorderThickness="1" BorderBrush="#DDD">
                        
                        <Image Source="{Binding PreviewImage}" Stretch="UniformToFill"/>
                    </Border>
                    <Button Command="{Binding SelectLogoCommand}" 
                            Content="CHOOSE LOGO" 
                            Margin="20,0,0,0" 
                            VerticalAlignment="Center"
                            Style="{StaticResource MaterialDesignRaisedButton}"/>
                </StackPanel>

                <!--<Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Latitude" Text="{Binding Provider.Latitude, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0" Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
                    <TextBox Grid.Column="1" materialDesign:HintAssist.Hint="Longitude" Text="{Binding Provider.Longitude, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
                </Grid>-->
            </StackPanel>
        <!--</ScrollViewer>-->

        <Border Grid.Row="1" Background="{DynamicResource MaterialDesignDivider}" Padding="15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="CANCEL" Command="{Binding CancelCommand}" 
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" 
                        Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,10,0"/>
                <Button Content="SAVE" Command="{Binding SaveCommand}" 
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" 
                        Style="{StaticResource MaterialDesignRaisedButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>