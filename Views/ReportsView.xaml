<UserControl x:Class="Meditrans.Client.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Meditrans.Client.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:Meditrans.Client.Helpers"
             xmlns:converters="clr-namespace:Meditrans.Client.Converters"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <!-- Convertidores -->
        <BooleanToVisibilityConverter x:Key="StandardBoolToVis" />
        <converters:AviataInverseVisibilityConverter x:Key="AviataInverseVisibilityConverter" />

        <!-- Style for individual FundingSource items -->
        <Style x:Key="MultiSelectComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <CheckBox Content="{Binding Name}" 
                                  IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"  
                                  Margin="10,2"
                                  HorizontalAlignment="Stretch"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GenerateButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15">
        <TabControl>
            <TabItem Header="Production Report" >
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Section for Report Parameters/Filters -->
                    <Border Grid.Row="0" Background="#F7F7F7" CornerRadius="5" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Report Options" FontSize="16" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,10"/>

                            <!-- Date Picker -->
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Select Report Date:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <!-- Bind the DatePicker to a property in the ViewModel -->
                                <DatePicker SelectedDate="{Binding SelectedDate}" Width="150" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- NEW: Funding Source ComboBox -->
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Funding Source:" VerticalAlignment="Center" Margin="0,0,10,0" Width="120"/>
                                <ComboBox ItemsSource="{Binding AllFundingSources}"
                              SelectedItem="{Binding SelectedFundingSource}"
                              DisplayMemberPath="Name"
                              Width="250"
                              VerticalAlignment="Center"/>
                            </StackPanel>

                        </StackPanel>
                    </Border>

                    <!-- Section for the Generate Button -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Button Command="{Binding GenerateProductionReportCommand}"
                                Style="{StaticResource GenerateButtonStyle}">
                            <!-- Change button content based on whether the report is being generated -->
                            <TextBlock Text="{Binding GenerateButtonText}"/>
                        </Button>
                        <TextBlock Text="Click the button to export the Production Report to an Excel file." 
                                   Foreground="Gray" 
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- GPS Report Tab -->
            <TabItem Header="GPS Report" >
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Section for Report Parameters/Filters -->
                    <Border Grid.Row="0" Background="#F7F7F7" CornerRadius="5" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Report Options" FontSize="16" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Select Report Date:" VerticalAlignment="Center" Margin="0,0,10,0" Width="120"/>
                                <DatePicker SelectedDate="{Binding SelectedDate}" Width="150" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Select Vehicle Route:" VerticalAlignment="Center" Margin="0,0,10,0" Width="120"/>
                                <ComboBox ItemsSource="{Binding AllVehicleRoutes}" 
                                          SelectedItem="{Binding SelectedVehicleRoute}"
                                          DisplayMemberPath="Name"
                                          Width="200"
                                          VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Section for the Generate Button -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Button Command="{Binding GenerateGpsReportCommand}"
                                Style="{StaticResource GenerateButtonStyle}">
                            <TextBlock Text="{Binding GenerateGpsButtonText}"/>
                        </Button>
                        <TextBlock Text="Select a date and route, then click to export the GPS Report." 
                                   Foreground="Gray" 
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Trip2 PDF Report Tab -->
            <TabItem Header="Trip2 PDF Report" >
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#F7F7F7" CornerRadius="5" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Trip2 PDF Generation" FontSize="16" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Select Report Date:" VerticalAlignment="Center" Margin="0,0,10,0" Width="120"/>
                                <DatePicker SelectedDate="{Binding SelectedDate}" Width="150" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Button Command="{Binding GenerateTrip2PdfCommand}"
                    Style="{StaticResource GenerateButtonStyle}">
                            <TextBlock Text="{Binding GenerateTrip2ButtonText}"/>
                        </Button>
                        <TextBlock Text="Export the Daily Trip Log to a PDF file." 
                       Foreground="Gray" 
                       Margin="0,10,0,0"
                       HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- AVIATA (Previsualización y Filtros) -->
            <TabItem Header="Aviata Report">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- FILTROS -->
                    <Border Grid.Column="0" Background="White" CornerRadius="5" Padding="15" Margin="0,0,10,0" BorderBrush="#DDD" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Aviata Billing Filters" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                            <TextBlock Text="Start Date:" Margin="0,10,0,5"/>
                            <DatePicker SelectedDate="{Binding StartDate}"/>

                            <TextBlock Text="End Date:" Margin="0,15,0,5"/>
                            <DatePicker SelectedDate="{Binding EndDate}"/>

                            <TextBlock Text="Funding Sources:" Margin="0,15,0,5"/>

                            <!-- Master CheckBox (Select All) placed above the ComboBox -->
                            <CheckBox Content="[ SELECT ALL SOURCES ]" 
                                      IsChecked="{Binding IsAllSelected}" 
                                      FontWeight="Bold" Margin="2,0,0,5"/>

                            <!-- Multi-selection ComboBox -->
                            <ComboBox ItemsSource="{Binding AllFundingSources}" 
                                      ItemContainerStyle="{StaticResource MultiSelectComboBoxItemStyle}"
                                      materialDesign:HintAssist.Hint="Filter by item..."
                                      SelectedItem="{Binding SelectedFundingSource}"/>

                            <Separator Margin="0,20"/>
                            <Button Command="{Binding PreviewAviataReportCommand}" Content="GENERATE PREVIEW" Style="{StaticResource GenerateButtonStyle}" Background="#673AB7"/>
                            <Button Command="{Binding SaveAviataReportCommand}" Content="SAVE AS PDF" IsEnabled="{Binding IsPreviewReady}" Style="{StaticResource GenerateButtonStyle}" Background="#2E7D32" Margin="0,10,0,0"/>

                            <ProgressBar IsIndeterminate="True" Margin="0,10" Visibility="{Binding IsGeneratingAviata, Converter={StaticResource StandardBoolToVis}}"/>
                        </StackPanel>
                    </Border>

                    <!-- PREVIEW -->
                    <Border Grid.Column="1" Background="#F0F0F0" CornerRadius="5" BorderBrush="#E0E0E0" BorderThickness="1">
                        <Grid>
                            <StackPanel VerticalAlignment="Center" Visibility="{Binding IsPreviewReady, Converter={StaticResource AviataInverseVisibilityConverter}}">
                                <materialDesign:PackIcon Kind="FilePdfBox" Width="60" Height="60" HorizontalAlignment="Center" Foreground="#BDBDBD"/>
                                <TextBlock Text="Click 'Generate Preview' to see the report." HorizontalAlignment="Center" Foreground="#9E9E9E"/>
                            </StackPanel>
                            <wv2:WebView2 x:Name="PdfWebView" 
                                  Source="{Binding PreviewFilePath}"
                                  Visibility="{Binding IsPreviewReady, Converter={StaticResource StandardBoolToVis}}"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>